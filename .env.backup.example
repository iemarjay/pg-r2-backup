# Postgres
PG_HOST=postgres
PG_PORT=5432
PG_USER=changeme
PG_PASSWORD=changeme
PG_DATABASE=changeme

# Cloudflare R2
R2_ACCOUNT_ID=changeme
R2_BUCKET=changeme-backups
R2_ACCESS_KEY_ID=changeme
R2_SECRET_ACCESS_KEY=changeme

# Encryption (store this somewhere safe AND separate from R2 creds)
ENCRYPTION_PASSPHRASE=changeme-long-random-string

# Schedule (default: 02:00 UTC daily)
BACKUP_CRON=0 2 * * *
BACKUP_NAME_PREFIX=myapp

